@{
    ViewData["Title"] = "Редагування доріг";
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: #0f172a;
            color: #e2e8f0;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Шапка ── */
        .header {
            background: #1e293b;
            border-bottom: 1px solid #334155;
            padding: 0.75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .header h1 { font-size: 1.1rem; font-weight: 700; color: #f1f5f9; }

        .header-nav { display: flex; gap: 0.5rem; }

        .nav-btn {
            padding: 0.4rem 0.9rem;
            border-radius: 0.375rem;
            font-size: 0.8rem;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid #475569;
            background: transparent;
            color: #94a3b8;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .nav-btn:hover { border-color: #94a3b8; color: #f1f5f9; }
        .nav-btn.active { background: #3b82f6; border-color: #3b82f6; color: white; }

        /* ── Тулбар ── */
        .toolbar {
            background: #1e293b;
            border-bottom: 1px solid #334155;
            padding: 0.5rem 1.5rem;
            display: flex;
            gap: 0.75rem;
            align-items: center;
            flex-shrink: 0;
        }

        .tool-btn {
            padding: 0.4rem 0.9rem;
            border-radius: 0.375rem;
            font-size: 0.8rem;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid #475569;
            background: transparent;
            color: #94a3b8;
            transition: all 0.2s;
        }

        .tool-btn:hover { border-color: #94a3b8; color: #f1f5f9; }

        .tool-btn.active {
            background: #1d4ed8;
            border-color: #3b82f6;
            color: white;
        }

        .tool-btn.success {
            background: #065f46;
            border-color: #059669;
            color: #34d399;
        }

        .toolbar-hint {
            font-size: 0.75rem;
            color: #64748b;
            margin-left: 0.5rem;
        }

        /* ── Основний layout ── */
        .main {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        #map { flex: 1; }

        /* ── Бічна панель ── */
        .side-panel {
            width: 320px;
            background: #1e293b;
            border-left: 1px solid #334155;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            flex-shrink: 0;
        }

        .panel-header {
            padding: 1rem;
            border-bottom: 1px solid #334155;
            font-size: 0.875rem;
            font-weight: 600;
            color: #f1f5f9;
        }

        .panel-body {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
        }

        .empty-hint {
            color: #475569;
            font-size: 0.8rem;
            text-align: center;
            margin-top: 2rem;
            line-height: 1.6;
        }

        /* ── Форма ── */
        .field { margin-bottom: 0.75rem; }

        .field label {
            display: block;
            font-size: 0.7rem;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.3rem;
        }

        .field input,
        .field select {
            width: 100%;
            padding: 0.45rem 0.6rem;
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 0.375rem;
            color: #e2e8f0;
            font-size: 0.8rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .field input:focus,
        .field select:focus { border-color: #3b82f6; }

        .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }

        .coords-display {
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 0.375rem;
            padding: 0.5rem 0.6rem;
            font-size: 0.75rem;
            color: #94a3b8;
            font-family: monospace;
            line-height: 1.6;
        }

        .coords-point {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .coords-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        /* ── Кнопки дій ── */
        .panel-actions {
            padding: 1rem;
            border-top: 1px solid #334155;
            display: flex;
            gap: 0.5rem;
        }

        .btn-save {
            flex: 1;
            padding: 0.6rem;
            background: #065f46;
            color: #34d399;
            border: 1px solid #059669;
            border-radius: 0.375rem;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-save:hover { background: #047857; }
        .btn-save:disabled { opacity: 0.5; cursor: default; }

        .btn-cancel {
            padding: 0.6rem 1rem;
            background: transparent;
            color: #94a3b8;
            border: 1px solid #475569;
            border-radius: 0.375rem;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-cancel:hover { border-color: #f87171; color: #f87171; }

        /* ── Toast ── */
        .toast {
            position: fixed;
            bottom: 1.5rem;
            right: 1.5rem;
            padding: 0.75rem 1.25rem;
            border-radius: 0.5rem;
            font-size: 0.875rem;
            font-weight: 500;
            z-index: 9999;
            transform: translateY(100px);
            opacity: 0;
            transition: all 0.3s;
        }

        .toast.show { transform: translateY(0); opacity: 1; }
        .toast.success { background: #065f46; color: #34d399; border: 1px solid #059669; }
        .toast.error { background: #450a0a; color: #f87171; border: 1px solid #dc2626; }

        /* ── Leaflet overrides ── */
        .leaflet-container { background: #1a2332; }

        .new-point-marker div {
            border: 2px solid white;
            box-shadow: 0 2px 6px rgba(0,0,0,0.4);
        }
    </style>
</head>
<body>

<div class="header">
    <h1>🛣️ Редагування доріг — Адмін-панель</h1>
    <div class="header-nav">
        <a href="/Admin/Reports" class="nav-btn">📋 Звіти</a>
        <a href="/Admin/Roads" class="nav-btn active">🗺️ Дороги</a>
            <a href="/Admin/Training" class="nav-btn">🤖 Моделі</a>
    </div>
</div>

<div class="toolbar">
    <button class="tool-btn active" id="btnModeSelect" onclick="setMode('select')">
        👆 Вибір
    </button>
    <button class="tool-btn" id="btnModeAdd" onclick="setMode('add')">
        ➕ Додати сегмент
    </button>
        <button class="tool-btn" id="btnConnectGraph" onclick="connectGraph()">
            🔗 З'єднати граф
        </button>
        <span id="connectStatus" style="font-size:0.75rem; color:#64748b;"></span>
    <span class="toolbar-hint" id="toolbarHint">Клікніть на сегмент дороги для редагування</span>
</div>

<div class="main">
    <div id="map"></div>

    <div class="side-panel">
        <div class="panel-header" id="panelTitle">Інформація</div>
        <div class="panel-body" id="panelBody">
            <div class="empty-hint">
                Оберіть режим і клікніть на карті
            </div>
        </div>
        <div class="panel-actions" id="panelActions" style="display:none;">
            <button class="btn-cancel" onclick="cancelEdit()">Скасувати</button>
            <button class="btn-save" id="btnSave" onclick="saveChanges()">💾 Зберегти</button>
        </div>
    </div>
</div>

<div class="toast" id="toast"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.js"></script>
<script>
    // ── Стан ─────────────────────────────────────────────────────────────────
    let map;
    let mode = 'select';        // 'select' | 'add'
    let segments = [];          // всі завантажені сегменти
    let polylines = [];         // Leaflet polylines
    let selectedSegment = null; // поточний вибраний сегмент для редагування
    let newPoints = [];         // точки нового сегменту (макс 2)
    let newMarkers = [];        // маркери нових точок
    let newPolyline = null;     // preview лінія нового сегменту
    let highlightPolyline = null; // підсвічений сегмент

    // ── Ініціалізація ────────────────────────────────────────────────────────
    function initMap() {
        map = L.map('map').setView([50.4501, 30.5234], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 19
        }).addTo(map);

        map.on('click', onMapClick);
    }

    async function loadSegments() {
        try {
            const res = await fetch('/api/accessibility/admin/roads');
            segments = await res.json();
            renderSegments();
        } catch (e) {
            showToast('Помилка завантаження доріг', 'error');
        }
    }

            async function deleteSegment(id) {
            if (!confirm(`Видалити сегмент #${id}? Це незворотно.`)) return;

            try {
                const res = await fetch(`/api/accessibility/admin/roads/${id}`, {
                    method: 'DELETE'
                });

                if (!res.ok) {
                    const err = await res.json();
                    showToast('Помилка: ' + err.message, 'error');
                    return;
                }

                showToast(`Сегмент #${id} видалено`, 'success');
                cancelEdit();
                await loadSegments();
            } catch (e) {
                showToast('Помилка: ' + e.message, 'error');
            }
        }

        async function connectGraph() {
            const btn = document.getElementById('btnConnectGraph');
            const status = document.getElementById('connectStatus');

            btn.disabled = true;
            btn.textContent = '⏳ З\'єднання...';
            status.textContent = '';

            try {
                const res = await fetch('/api/accessibility/sidewalks-with-bridges', {
                    method: 'GET'
                });

                if (!res.ok) {
                    const err = await res.json();
                    showToast('Помилка: ' + err.message, 'error');
                    return;
                }

                const data = await res.json();
                status.textContent = `Доріг: ${data.totalRoads}, штучних ребер: ${data.totalBridges}`;
                showToast('Граф з\'єднано ✓', 'success');
            } catch (e) {
                showToast('Помилка: ' + e.message, 'error');
            } finally {
                btn.disabled = false;
                btn.textContent = '🔗 З\'єднати граф';
            }
        }

    function renderSegments() {
        polylines.forEach(p => map.removeLayer(p));
        polylines = [];

        segments.forEach(seg => {
            if (!seg.coordinates || seg.coordinates.length < 2) return;

            for (let i = 0; i < seg.coordinates.length - 1; i++) {
                const coords = [
                    [seg.coordinates[i][0], seg.coordinates[i][1]],
                    [seg.coordinates[i + 1][0], seg.coordinates[i + 1][1]]
                ];

                const pl = L.polyline(coords, {
                    color: '#3b82f6',
                    weight: 3,
                    opacity: 0.7
                }).addTo(map);

                pl.on('click', (e) => {
                    L.DomEvent.stopPropagation(e);
                    if (mode === 'select') selectSegment(seg, pl);
                });

                pl.on('mouseover', () => { if (mode === 'select') pl.setStyle({ color: '#60a5fa', weight: 5 }); });
                pl.on('mouseout',  () => { if (pl !== highlightPolyline) pl.setStyle({ color: '#3b82f6', weight: 3 }); });

                polylines.push(pl);
            }
        });
    }

    // ── Режими ───────────────────────────────────────────────────────────────
    function setMode(m) {
        mode = m;
        cancelEdit();

        document.getElementById('btnModeSelect').classList.toggle('active', m === 'select');
        document.getElementById('btnModeAdd').classList.toggle('active', m === 'add');

        const hints = {
            select: 'Клікніть на сегмент дороги для редагування',
            add: 'Клікніть першу точку сегменту (S), потім другу (F)'
        };
        document.getElementById('toolbarHint').textContent = hints[m];
    }

    // ── Клік на карті ────────────────────────────────────────────────────────
    function onMapClick(e) {
        if (mode !== 'add') return;

        if (newPoints.length >= 2) return;

        newPoints.push([e.latlng.lat, e.latlng.lng]);

        const label = newPoints.length === 1 ? 'S' : 'F';
        const color = newPoints.length === 1 ? '#10b981' : '#ef4444';

        const marker = L.marker([e.latlng.lat, e.latlng.lng], {
            icon: L.divIcon({
                className: 'new-point-marker',
                html: `<div style="background:${color};color:white;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:0.75rem;">${label}</div>`,
                iconSize: [28, 28]
            })
        }).addTo(map);

        newMarkers.push(marker);

        if (newPoints.length === 2) {
            // Малюємо preview лінію
            if (newPolyline) map.removeLayer(newPolyline);
            newPolyline = L.polyline(newPoints, {
                color: '#f59e0b',
                weight: 3,
                dashArray: '6, 4'
            }).addTo(map);

            showAddForm();
        }
    }

    // ── Вибір існуючого сегменту ─────────────────────────────────────────────
    function selectSegment(seg, polyline) {
        // Скидаємо попередній highlight
        if (highlightPolyline) {
            highlightPolyline.setStyle({ color: '#3b82f6', weight: 3 });
        }

        selectedSegment = seg;
        highlightPolyline = polyline;
        polyline.setStyle({ color: '#f59e0b', weight: 5 });

        showEditForm(seg);
    }

    // ── Форма редагування існуючого ──────────────────────────────────────────
            function showEditForm(seg) {
            document.getElementById('panelTitle').textContent = `✏️ Редагування сегменту #${seg.id}`;
            document.getElementById('panelActions').style.display = 'flex';

            const c = seg.coordinates;
            const coordsHtml = c && c.length >= 2 ? `
                <div class="coords-point">
                    <div class="coords-dot" style="background:#10b981;"></div>
                    <span>${c[0][0].toFixed(6)}, ${c[0][1].toFixed(6)}</span>
                </div>
                <div class="coords-point" style="margin-top:0.3rem;">
                    <div class="coords-dot" style="background:#ef4444;"></div>
                    <span>${c[1][0].toFixed(6)}, ${c[1][1].toFixed(6)}</span>
                </div>
            ` : '—';

            document.getElementById('panelBody').innerHTML = `
                <div class="field">
                    <label>Координати</label>
                    <div class="coords-display">${coordsHtml}</div>
                </div>
                <button onclick="deleteSegment(${seg.id})"
                        style="width:100%; padding:0.4rem; background:#450a0a; color:#f87171;
                               border:1px solid #dc2626; border-radius:0.375rem; font-size:0.75rem;
                               cursor:pointer; margin-bottom:0.75rem;">
                    🗑️ Видалити сегмент
                </button>
                <div class="field">
                    <label>Назва</label>
                    <input id="f-name" value="${seg.name || ''}">
                </div>
                <div class="field-row">
                    <div class="field">
                        <label>Тип</label>
                        ${typeSelect('f-type', seg.type)}
                    </div>
                    <div class="field">
                        <label>Ширина (м)</label>
                        <input id="f-width" type="number" step="0.1" value="${seg.width || ''}">
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label>Покриття</label>
                        ${surfaceSelect('f-surface', seg.surface)}
                    </div>
                    <div class="field">
                        <label>Якість</label>
                        ${smoothnessSelect('f-smoothness', seg.smoothness)}
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label>Освітлення</label>
                        ${yesNoSelect('f-lit', seg.lit)}
                    </div>
                    <div class="field">
                        <label>Тактильна плитка</label>
                        ${yesNoSelect('f-tactile', seg.tactile_paving)}
                    </div>
                </div>
                <div class="field">
                    <label>Доступність для візків</label>
                    ${yesNoSelect('f-wheelchair', seg.wheelchair)}
                </div>
            `;
        }

    // ── Форма додавання нового ───────────────────────────────────────────────
    function showAddForm() {
        document.getElementById('panelTitle').textContent = '➕ Новий сегмент';
        document.getElementById('panelActions').style.display = 'flex';

        const p = newPoints;
        const coordsHtml = `
            <div class="coords-point">
                <div class="coords-dot" style="background:#10b981;"></div>
                <span>${p[0][0].toFixed(6)}, ${p[0][1].toFixed(6)}</span>
            </div>
            <div class="coords-point" style="margin-top:0.3rem;">
                <div class="coords-dot" style="background:#ef4444;"></div>
                <span>${p[1][0].toFixed(6)}, ${p[1][1].toFixed(6)}</span>
            </div>
        `;

        document.getElementById('panelBody').innerHTML = `
            <div class="field">
                <label>Координати сегменту</label>
                <div class="coords-display">${coordsHtml}</div>
            </div>
            <div class="field">
                <label>Назва вулиці</label>
                <input id="f-name" placeholder="напр. вулиця Хрещатик">
            </div>
            <div class="field-row">
                <div class="field">
                    <label>Тип</label>
                    ${typeSelect('f-type', 'footway')}
                </div>
                <div class="field">
                    <label>Ширина (м)</label>
                    <input id="f-width" type="number" step="0.1" placeholder="1.5">
                </div>
            </div>
            <div class="field-row">
                <div class="field">
                    <label>Покриття</label>
                    ${surfaceSelect('f-surface', '')}
                </div>
                <div class="field">
                    <label>Якість</label>
                    ${smoothnessSelect('f-smoothness', '')}
                </div>
            </div>
            <div class="field-row">
                <div class="field">
                    <label>Освітлення</label>
                    ${yesNoSelect('f-lit', 'no')}
                </div>
                <div class="field">
                    <label>Тактильна плитка</label>
                    ${yesNoSelect('f-tactile', 'no')}
                </div>
            </div>
            <div class="field">
                <label>Доступність для візків</label>
                ${yesNoSelect('f-wheelchair', 'no')}
            </div>
        `;
    }

    // ── Збереження ───────────────────────────────────────────────────────────
    async function saveChanges() {
        const btn = document.getElementById('btnSave');
        btn.disabled = true;
        btn.textContent = 'Збереження...';

        try {
            if (mode === 'select' && selectedSegment) {
                await saveEdit();
            } else if (mode === 'add' && newPoints.length === 2) {
                await saveNew();
            }
        } finally {
            btn.disabled = false;
            btn.textContent = '💾 Зберегти';
        }
    }

    async function saveEdit() {
        const body = {
            name:          val('f-name')       || null,
            type:          val('f-type')       || null,
            surface:       val('f-surface')    || null,
            smoothness:    val('f-smoothness') || null,
            lit:           val('f-lit')        || null,
            tactilePaving: val('f-tactile')    || null,
            wheelchair:    val('f-wheelchair') || null,
            width:         numVal('f-width')
        };

        const res = await fetch(`/api/accessibility/admin/roads/${selectedSegment.id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });

        if (!res.ok) {
            const err = await res.json();
            showToast('Помилка: ' + err.message, 'error');
            return;
        }

        showToast('Сегмент збережено ✓', 'success');
        cancelEdit();
        await loadSegments();
    }

    async function saveNew() {
        const body = {
            name:          val('f-name'),
            type:          val('f-type'),
            coordinates:   newPoints,
            surface:       val('f-surface'),
            smoothness:    val('f-smoothness'),
            lit:           val('f-lit'),
            tactilePaving: val('f-tactile'),
            wheelchair:    val('f-wheelchair'),
            width:         numVal('f-width') ?? 0
        };

        const res = await fetch('/api/accessibility/admin/roads', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });

        if (!res.ok) {
            const err = await res.json();
            showToast('Помилка: ' + err.message, 'error');
            return;
        }

        const data = await res.json();
        showToast(`Сегмент #${data.id} додано ✓`, 'success');
        cancelEdit();
        await loadSegments();
    }

    // ── Скасування / очищення ────────────────────────────────────────────────
    function cancelEdit() {
        // Скидаємо highlight
        if (highlightPolyline) {
            highlightPolyline.setStyle({ color: '#3b82f6', weight: 3 });
            highlightPolyline = null;
        }
        selectedSegment = null;

        // Прибираємо точки нового сегменту
        newMarkers.forEach(m => map.removeLayer(m));
        newMarkers = [];
        newPoints = [];
        if (newPolyline) { map.removeLayer(newPolyline); newPolyline = null; }

        // Скидаємо панель
        document.getElementById('panelTitle').textContent = 'Інформація';
        document.getElementById('panelBody').innerHTML = `<div class="empty-hint">Оберіть режим і клікніть на карті</div>`;
        document.getElementById('panelActions').style.display = 'none';
    }

    // ── Допоміжні select-и ───────────────────────────────────────────────────
    function typeSelect(id, val) {
        const opts = ['footway','path','sidewalk','secondary','primary','residential','tertiary','service','cycleway','steps'];
        return `<select id="${id}">${opts.map(o => `<option value="${o}" ${o===val?'selected':''}>${o}</option>`).join('')}</select>`;
    }

    function surfaceSelect(id, val) {
        const opts = [['','— невідомо —'],['asphalt','asphalt'],['concrete','concrete'],['paving_stones','paving_stones'],['sett','sett'],['gravel','gravel'],['unpaved','unpaved'],['grass','grass'],['dirt','dirt']];
        return `<select id="${id}">${opts.map(([v,l]) => `<option value="${v}" ${v===val?'selected':''}>${l}</option>`).join('')}</select>`;
    }

    function smoothnessSelect(id, val) {
        const opts = [['unknown','unknown'],['excellent','excellent'],['good','good'],['intermediate','intermediate'],['bad','bad'],['very_bad','very_bad'],['horrible','horrible']];
        return `<select id="${id}">${opts.map(([v,l]) => `<option value="${v}" ${v===val?'selected':''}>${l}</option>`).join('')}</select>`;
    }

    function yesNoSelect(id, val) {
        return `<select id="${id}">
            <option value="yes" ${val==='yes'?'selected':''}>yes</option>
            <option value="no"  ${val==='no' ?'selected':''}>no</option>
        </select>`;
    }

    function val(id) {
        return document.getElementById(id)?.value?.trim() || null;
    }

    function numVal(id) {
        const v = parseFloat(document.getElementById(id)?.value);
        return isNaN(v) ? null : v;
    }

    // ── Toast ────────────────────────────────────────────────────────────────
    function showToast(msg, type = 'success') {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.className = `toast ${type} show`;
        setTimeout(() => t.classList.remove('show'), 3000);
    }

    // ── Старт ────────────────────────────────────────────────────────────────
    initMap();
    loadSegments();
</script>
</body>
</html>
